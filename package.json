{
  "name": "@adrianhall/cloudflare-toolkit",
  "version": "2.0.0",
  "description": "A toolkit of utilities and skills for developing Workers on the Cloudflare Dev Platform",
  "keywords": [
    "cloudflare",
    "cloudflare-workers",
    "workers",
    "wrangler",
    "hono",
    "vite",
    "typescript",
    "problem-details",
    "logging",
    "cloudflare-access"
  ],
  "homepage": "https://adrianhall.github.io/cloudflare-toolkit",
  "bugs": {
    "url": "https://github.com/adrianhall/cloudflare-toolkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianhall/cloudflare-toolkit.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "license": "MIT",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "import": "./dist/guards/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./problem-details": {
      "types": "./dist/problem-details/index.d.ts",
      "import": "./dist/problem-details/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.js"
    },
    "./hono": {
      "types": "./dist/hono/index.d.ts",
      "import": "./dist/hono/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "bin": {
    "generate-wrangler-types": "./dist/cli/generate-wrangler-types/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "THIRD-PARTY-NOTICES.md"
  ],
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "peerDependencies": {
    "hono": "^4.12.28",
    "vite": "^8.1.4"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "cross-spawn": "^7.0.6",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vitest-pool-workers": "^0.18.3",
    "@cloudflare/workers-types": "5.20260708.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^26.1.1",
    "@vitest/coverage-istanbul": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-plugin-jsdoc": "^63.0.12",
    "hono": "^4.12.28",
    "husky": "^9.1.7",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.5",
    "shx": "^0.4.0",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.109.0"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "check": "run-s check:types check:lint check:format check:pack",
    "check:format": "prettier --check .",
    "check:lint": "eslint .",
    "check:pack": "npm pack --ignore-scripts --dry-run",
    "check:types": "tsc --noEmit",
    "docs:build": "npm --prefix docs run build",
    "docs:clean": "shx rm -rf docs/reference docs/.vitepress/cache docs/.vitepress/dist",
    "docs:dev": "npm --prefix docs run dev",
    "prepare": "husky",
    "pretest": "npm run build",
    "pretest:coverage": "npm run build",
    "release": "npm run build && changeset publish",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "version-packages": "changeset version && prettier --write ."
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "workerd@1.20260708.1": true
  }
}
