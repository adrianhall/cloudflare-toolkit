{
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "checkIgnorePragma": true,
  "endOfLine": "lf",
  "experimentalTernaries": true,
  "experimentalOperatorPosition": "start",
  "htmlWhitespaceSensitivity": "css",
  "jsxSingleQuote": false,
  "objectWrap": "preserve",
  "printWidth": 100,
  "quoteProps": "consistent",
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "none"
}
